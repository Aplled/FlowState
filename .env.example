VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Node classification (LLM) is now handled by the `groq-classify` Supabase
# Edge Function. There is NO client-side Groq key anymore — deploy the
# function and set the key as a Supabase secret:
#
#   supabase functions deploy groq-classify
#   supabase secrets set GROQ_API_KEY=gsk_...
#
# If you previously had VITE_GROQ_API_KEY in your local .env, delete it and
# rotate the Groq key (the old one lived in the client bundle and is likely
# compromised).
